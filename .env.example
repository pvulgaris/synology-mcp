# Copy this to `.env` on the NAS at /volume1/docker/synology-mcp/.env
# You usually need NO .env at all — the compose has defaults for the config, and the
# secrets are the *_FILE files you upload into secrets/. Add a line only to override a
# default (below).

# Required:
DSM_BASE_URL=https://localhost:5001

# Credentials: the daemon reads DSM_PASSWORD / DSM_TOTP_SECRET / MCP_BEARER_TOKEN from
# the bind-mounted *_FILE files — upload dsm_password / dsm_totp / mcp_bearer into
# secrets/ (see docs/SETUP.md → "Credentials"). Nothing to set here for that.
# Want secrets RAM-only instead of files? Set DSM_PASSWORD / DSM_TOTP_SECRET /
# MCP_BEARER_TOKEN in the compose `environment:` at launch from your own secret
# manager (op run / sops) — the server has no built-in secret-manager dependency.

# Optional (defaults shown):
# DSM_USER=claude-mcp
# MCP_BIND_HOST=                                       # empty = auto-detect (binds 0.0.0.0 here → LAN-reachable).
#                                                      # Set 127.0.0.1 to bind loopback only and front it with
#                                                      # `tailscale serve` (tailnet-only, no LAN exposure). See docs/SETUP.md.
# MCP_BIND_PORT=8765
# MCP_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,null
# TLS_REJECT_UNAUTHORIZED=0

# Optional — Synology router (SRM) target. Unset = NAS-only. The router's
# package/upgrade reads are admin-gated, so SRM_USER must be a dedicated SRM admin
# (claude-mcp-style; used read-only). Upload srm_password + srm_totp into secrets/
# (same *_FILE convention as DSM), and set:
# SRM_BASE_URL=https://router.local:8001
# SRM_USER=claude-mcp
