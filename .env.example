# Copy this to `.env` on the NAS at /volume1/docker/synology-nas-mcp/.env
# Never commit the real .env — it contains a long-lived 1Password service-account token.

# Required:
OP_SERVICE_ACCOUNT_TOKEN=ops_replace_me
DSM_BASE_URL=https://localhost:5001
DSM_OP_VAULT=Claude

# Optional (defaults shown):
# DSM_OP_ITEM=Synology DSM - claude-mcp
# DSM_USER=claude-mcp
# MCP_BIND_HOST=                                       # leave empty for auto-detect
# MCP_BIND_PORT=8765
# MCP_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,null
# TLS_REJECT_UNAUTHORIZED=0
