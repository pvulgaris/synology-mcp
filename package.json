{
  "name": "synology-cli",
  "version": "0.5.0",
  "description": "Command-line access to a Synology NAS (DSM 7) and SRM router — packages, security audit, shares, snapshots, backups, storage health, cross-device update detection, and a raw escape hatch to any DSM Web API endpoint.",
  "type": "module",
  "license": "MIT",
  "author": "Peter Vulgaris",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pvulgaris/synology-cli.git"
  },
  "homepage": "https://github.com/pvulgaris/synology-cli#readme",
  "bugs": "https://github.com/pvulgaris/synology-cli/issues",
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "synology",
    "dsm",
    "nas",
    "srm",
    "cli"
  ],
  "bin": {
    "syno": "dist/cli.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "dev": "tsx src/cli.ts",
    "verify": "tsx src/dev/verify-tools.ts",
    "test": "node --import tsx --test --test-force-exit src/*.test.ts src/tools/*.test.ts"
  },
  "dependencies": {
    "otplib": "^12.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.0"
  }
}
